# Cloudflare Pages HTTP headers (security hardening; mirrors the in-page CSP).
/*
  Content-Security-Policy: default-src 'none'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self'; form-action https://redcap.ualberta.ca https://redcap.hhrinstitute.org; base-uri 'none'; frame-ancestors 'none'
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: no-referrer
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Cross-Origin-Opener-Policy: same-origin
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload

# Never cache the entry document, so dictionary/app updates take effect immediately.
/index.html
  Cache-Control: no-cache

# The app's JS (passphrase hash in config.js, form logic, dictionaries) changes on deploy —
# never cache it, so a passphrase/content change takes effect on the next load instead of
# being stuck behind the default ~4-hour asset cache. (Revalidates via ETag, so it's cheap.)
/config.js
  Cache-Control: no-cache
/*.js
  Cache-Control: no-cache
/*.json
  Cache-Control: no-cache
